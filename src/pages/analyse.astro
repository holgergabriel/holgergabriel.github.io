---
import Layout from "../layouts/BaseLayout.astro";
---

<Layout title="Analyse">

  <main class="analysis">

    <div id="app">

      <!-- INPUT -->
      <section id="input">
        <p>RR-Datei hochladen</p>
        <input type="file" />

        <p>Wahrnehmung</p>
        <input type="range" min="0" max="10" />

        <br /><br />
        <button id="startBtn">Analyse beginnen</button>
      </section>

      <!-- PROCESSING -->
      <section id="processing" hidden>
        <p>Analyse läuft.</p>
      </section>

      <!-- RESULT -->
      <section id="result" hidden>
        <p id="line1" class="line"></p>
        <p id="line2" class="line"></p>
        <p id="line3" class="line"></p>

        <p id="detailsTrigger" hidden>Details ansehen</p>
      </section>

      <!-- DETAILS -->
      <section id="details" hidden>
        <p>Hier kommen später Graphen etc.</p>
      </section>

    </div>

  </main>

<style>
  .line {
    opacity: 0;
    transition: opacity 0.8s ease;
  }

  .line.visible {
    opacity: 1;
  }

  #detailsTrigger {
    margin-top: 2rem;
    opacity: 0.6;
    cursor: pointer;
  }
</style>

<script>
  const TEXT = {
    line1: "Die rhythmische Dynamik im Körper ist klar organisiert und deutlich ausgeprägt.",
    line2: "Zwischen dieser Organisation und deiner wahrgenommenen Atmung besteht Übereinstimmung.",
    line3: "Deine Stimme und diese Dynamik bewegen sich in enger Abstimmung."
  };

  function wait(ms) {
    return new Promise(resolve => setTimeout(resolve, ms));
  }

  function setText(id, text) {
    const el = document.getElementById(id);
    el.textContent = text;
    el.classList.add("visible");
  }

  function show(id) {
    document.getElementById(id).hidden = false;
  }

  function hide(id) {
    document.getElementById(id).hidden = true;
  }

function readingTime(text) {
  const words = text.split(" ").length;
  return words * 200;
}

  async function showResult() {
    show("result");

    setText("line1", TEXT.line1);
await wait(readingTime(TEXT.line1));

setText("line2", TEXT.line2);
await wait(readingTime(TEXT.line2));

setText("line3", TEXT.line3);

    show("detailsTrigger");
  }

  async function startAnalysis() {
    hide("input");
    show("processing");

    await wait(1200);

    hide("processing");

    hide("result");

    await showResult();
  }

  document.addEventListener("DOMContentLoaded", () => {
  document.getElementById("startBtn")
    .addEventListener("click", startAnalysis);

  document.getElementById("detailsTrigger")
    .addEventListener("click", () => {
      show("details");
    });
});

  document.getElementById("detailsTrigger")
    .addEventListener("click", () => {
      show("details");
    });
</script>

</Layout>