---
/**
 * MarkdownLayout
 */

import BaseLayout from './BaseLayout.astro';

interface Props {
  frontmatter: {
    title: string;
    description?: string;
    subtitle?: string;
    avatar?: string;
    avatarWidth?: string;
    avatarHeight?: string;
    highlight?: string;
  };
}

const { frontmatter } = Astro.props;
const avatarWidth = frontmatter.avatarWidth ?? '96px';
const avatarHeight = frontmatter.avatarHeight ?? '96px';

/* ---- Navigation ---- */
const path = Astro.url.pathname;

/* ---- Seitenlisten ---- */
const physiologiePages = [
  { title: "Ein Verständnis von Körper und Üben", slug: "verstaendnis" },
  { title: "Grundlagen des Singens", slug: "unterseite_1" },
  { title: "Atmung und Ton", slug: "unterseite_2" },
  { title: "Spannung und Leichtigkeit", slug: "unterseite_3" },
  { title: "Stimme als Entwicklung", slug: "unterseite_4" },
  { title: "Häufige Missverständnisse", slug: "unterseite_5" },
  { title: "Singen im Alltag", slug: "unterseite_6" },
  { title: "Wie man übt (ohne sich zu überfordern)", slug: "unterseite_7" },
  { title: "Inhaltliche Brücken zur Sportmedizin", slug: "sportmedizin" },
  { title: "Nutzung dieser Seiten", slug: "nutzung" },
  { title: "Einordnung dieser Seiten", slug: "keinangebot" },
];

const profilPages = [
  { title: "Worum es mir auf dieser Webseite geht", slug: "" },
  { title: "Hintergrund", slug: "hintergrund" },
  { title: "Gesundheit", slug: "gesundheit" },
  { title: "Persönliches", slug: "vorbemerkungen" },
  { title: "Repertoire", slug: "repertoire" },
];


/* ---- Bereich erkennen ---- */
let pages = [];
let basePath = "";

if (path.startsWith('/physiologie')) {
  pages = physiologiePages;
  basePath = '/physiologie';
} else if (path.startsWith('/profil')) {
  pages = profilPages;
  basePath = '/profil';
}

/* ---- aktuelle Position ---- */
const currentIndex = pages.findIndex(p => {
  if (p.slug === "") return path === basePath || path === basePath + "/";
  return path.includes(p.slug);
});

const prev = pages[currentIndex - 1];
const next = pages[currentIndex + 1];
---

<BaseLayout title={frontmatter.title} description={frontmatter.description}>
  <div class="container">
    <div class:list={['page-header', { 'page-header--with-avatar': frontmatter.avatar }]}>
      {frontmatter.avatar && (
        <img src={frontmatter.avatar} alt="" class="page-header__avatar" aria-hidden="true" style={`width:${avatarWidth};height:${avatarHeight}`} />
      )}
      <div>
        <h1 class="page-title">{frontmatter.title}</h1>
        {frontmatter.subtitle && <p class="page-subtitle">{frontmatter.subtitle}</p>}

        {frontmatter.highlight && (
            <p class="highlight">{frontmatter.highlight}</p>
  )}
      </div>
    </div>

    <article class="prose">
      <slot />

      {/* ---- Navigation ---- */}
      {currentIndex !== -1 && (
        <>

          <div class="nav-links">
            <div>
              {prev && (
                <a href={`${basePath}/${prev.slug ? prev.slug + '/' : ''}`}>
                  ← {prev.title}
                </a>
              )}
            </div>

            <div class="nav-next">
              {next && (
                <a href={`${basePath}/${next.slug ? next.slug + '/' : ''}`}>
                  {next.title} →
                </a>
              )}
            </div>
          </div>

          <p class="nav-progress">
            Abschnitt {currentIndex + 1} von {pages.length}
          </p>
        </>
      )}
    </article>
  </div>
</BaseLayout>

<style>
  /* ---- Page header ---- */
  .page-header {
    margin-bottom: var(--space-lg);
    padding-bottom: var(--space-lg);
    border-bottom: none;
  }

  .page-header--with-avatar {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
  }

  .page-header__avatar {
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
  }

  .page-title {
    margin-bottom: 0;
  }

  .page-subtitle {
    font-family: var(--font-ui);
    font-size: 1rem;
    color: var(--color-text-muted);
    margin-top: var(--space-sm);
    margin-bottom: 0;
    max-width: 60ch;
  }

  /* ---- Markdown prose styles ---- */
  .prose :global(h2) {
    font-family: var(--font-ui);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-top: var(--space-lg);
    margin-bottom: var(--space-lg);
    padding-bottom: var(--space-sm);
    border-bottom: 1px solid var(--color-border);
  }

  .prose :global(h2:first-child) {
    margin-top: 0;
  }

  .prose :global(h3) {
    font-family: var(--font-ui);
    font-size: 1rem;
    font-weight: 600;
    margin-top: var(--space-lg);
    margin-bottom: var(--space-sm);
  }

  .prose :global(p) {
    margin-bottom: var(--space-md);
    max-width: 70ch;
  }

  .prose :global(ul),
  .prose :global(ol) {
    padding-left: var(--space-lg);
    margin-bottom: var(--space-md);
  }

  .prose :global(li) {
    margin-bottom: var(--space-sm);
    line-height: 1.7;
  }

  .prose :global(a) {
    color: var(--color-text);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: var(--space-xl) 0;
  }

  .prose :global(blockquote) {
    border-left: 3px solid var(--color-text);
    background: var(--color-bg-alt);
    padding: var(--space-md) var(--space-lg);
    margin: var(--space-md) 0;
    font-style: italic;
  }

  /* ---- Navigation ---- */
  .nav-links {
    display: flex;
    justify-content: space-between;
    margin-top: var(--space-lg);
    font-size: 0.95em;
  }

  .nav-next {
    text-align: right;
  }

    .nav-progress {
    text-align: center;
    margin-top: var(--space-sm);
    font-size: 0.85em;
    color: var(--color-text-muted);
  }

  /* ---- Audio ---- */
  .prose :global(audio) {
    display: block;
    width: 100%;
    max-width: 500px;
    margin-top: var(--space-md);
  }
</style>