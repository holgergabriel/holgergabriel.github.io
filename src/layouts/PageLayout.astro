---
/**
 * PageLayout
 *
 * A standard content page layout that wraps content inside a centered
 * container with an optional page heading and subtitle.
 *
 * Extends BaseLayout.
 *
 * Props:
 *   title       – Page title (used for both <head> and the visible heading)
 *   description – Meta description
 *   subtitle    – Optional sub-heading displayed below the main title
 *   showHeading – Whether to render the page heading block (default: true)
 */

import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description?: string;
  subtitle?: string;
  showHeading?: boolean;
}

const {
  title,
  description,
  subtitle,
  showHeading = true,
} = Astro.props;
---

<BaseLayout title={title} description={description}>
  <div class="container">
    {showHeading && (
      <div class="page-header">
        <h1 class="page-title">{title}</h1>
        {subtitle && <p class="page-subtitle">{subtitle}</p>}
      </div>
    )}

    <slot />
  </div>
</BaseLayout>

<style>
  .page-header {
    margin-bottom: var(--space-xl);
    padding-bottom: var(--space-lg);
    border-bottom: 1px solid var(--color-border);
  }

  .page-title {
    margin-bottom: 0;
  }

  .page-subtitle {
    font-family: var(--font-ui);
    font-size: 1rem;
    color: var(--color-text-muted);
    margin-top: var(--space-sm);
    margin-bottom: 0;
    max-width: 60ch;
  }
</style>
